{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amtp.tech/schema/identity.schema.json",
  "title": "AMTP Identity Claim",
  "description": "A signed Nostr event (kind 24403) in which a key holder claims an address. The key side of the mutual name@domain <-> npub binding (SPEC 3.1). Replaceable: for a given pubkey+address, the highest created_at wins. Valid only if the domain's NIP-05 nostr.json also maps the name to this pubkey.",
  "type": "object",
  "required": ["id", "pubkey", "created_at", "kind", "tags", "content", "sig"],
  "properties": {
    "id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "pubkey": { "type": "string", "pattern": "^[0-9a-f]{64}$", "description": "The key claiming the address." },
    "created_at": { "type": "integer", "description": "Latest wins (replaceable)." },
    "kind": { "const": 24403 },
    "content": { "type": "string", "description": "Optional human-readable note; not normative." },
    "sig": { "type": "string", "pattern": "^[0-9a-f]{128}$" },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
      "contains": {
        "type": "array",
        "minItems": 2,
        "prefixItems": [
          { "const": "address" },
          { "type": "string", "pattern": "^[^@\\s]+@[^@\\s]+$" }
        ]
      },
      "description": "MUST contain at least one ['address','name@domain'] tag."
    }
  },
  "$comment": "Verification (SPEC 3.1): a binding is valid iff (1) GET https://domain/.well-known/nostr.json?name=name maps name -> this pubkey, AND (2) this current kind-24403 event signed by that pubkey claims name@domain.",
  "examples": [
    {
      "id": "8888888888888888888888888888888888888888888888888888888888888888",
      "pubkey": "1111111111111111111111111111111111111111111111111111111111111111",
      "created_at": 1780000000,
      "kind": 24403,
      "tags": [
        ["address", "motoko@amtp.tech"]
      ],
      "content": "",
      "sig": "99999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999"
    }
  ]
}
